# The Belfry — environment
#
# Copy to `.env` and fill in from your Supabase project:
#   Dashboard -> Project Settings -> API
#
# Leave these unset to run the app guest-only: local boards, no login, no
# network. That is the correct configuration for a fork or a public demo.
#
# VITE_SUPABASE_ANON_KEY accepts either key type: the newer publishable key
# (sb_publishable_...) or the legacy anon JWT (eyJ...). Supabase now recommends
# the publishable key; both are passed to createClient identically.
#
# Both values below are compiled into the JavaScript bundle and are PUBLIC.
# That is by design — the key grants only what Row Level Security allows, and
# supabase/schema.sql grants the anon role nothing.
#
# NEVER add the service_role key here, or to any VITE_ variable. It bypasses RLS
# entirely and would be readable by every visitor via View Source.

VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key
